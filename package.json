{
  "name": "quoteatlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "QuoteAtlas — offline-first ambient quote display (web · desktop · Android)",
  "license": "GPL-3.0-only",
  "author": "poli0981 / SkullMute",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24 <26",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "tauri android build --apk --target aarch64",
    "lint": "eslint .",
    "format": "prettier -w .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "i18n:check": "tsx scripts/check-i18n-parity.ts",
    "validate:data": "tsx scripts/validate-data.ts",
    "subset:fonts": "tsx scripts/subset-fonts.ts",
    "gen:attributions": "tsx scripts/gen-attributions.ts",
    "gen:tzmap": "tsx scripts/gen-tz-map.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-store": "^2.4.3",
    "i18next": "^26.3.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "^17.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "4.3.2",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.20.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "knip": "^5.44.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "subset-font": "^2.5.0",
    "tailwindcss": "4.3.2",
    "tsx": "^4.19.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.24.0",
    "vite": "8.1.3",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^4.1.0"
  }
}
