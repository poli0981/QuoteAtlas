{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "index.schema.json",
  "title": "QuoteAtlas locale index",
  "type": "object",
  "additionalProperties": false,
  "required": ["dataVersion", "generated", "locales"],
  "properties": {
    "dataVersion": { "type": "integer", "minimum": 1 },
    "generated": { "type": "string" },
    "locales": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "file", "count", "dir", "fontKey", "regions"],
        "properties": {
          "code": { "type": "string", "minLength": 2 },
          "file": { "type": "string", "pattern": "\\.json$" },
          "count": { "type": "integer", "minimum": 0 },
          "dir": { "enum": ["ltr", "rtl"] },
          "fontKey": { "type": "string" },
          "regions": { "type": "array", "items": { "type": "string", "pattern": "^[A-Z]{2}$" } }
        }
      }
    }
  }
}
