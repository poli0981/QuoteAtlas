# Local-only project spec — MUST NEVER be committed/pushed (maintainer constraint)
/docs/
/CLAUDE.md

# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/

# Test / coverage artifacts
coverage/
playwright-report/
test-results/
blob-report/
.playwright/

# Tauri. The generated src-tauri/gen/android project IS tracked (for reproducible
# signed builds + committed manifest/gradle hardening); its own .gitignore excludes
# build artifacts (build/, .gradle/, .cxx/, keystore.properties, local.properties).
src-tauri/target/
src-tauri/gen/schemas/
src-tauri/gen/apple/

# Font source workspace — source OFL TTFs are supplied by a human, not committed;
# only the subset public/fonts/*.woff2 outputs are tracked
fonts-src/

# Content import build artifact (the 5 content-src/*.md sources ARE committed)
content-src/provenance.report.md

# Environment / local overrides
.env
.env.*
!.env.example
*.local

# Editor / OS / agent tooling (local-only)
.idea/
.vscode/*
!.vscode/extensions.json
.claude/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
