# Copy to `keystore.properties` (gitignored) to build a SIGNED release APK.
# The signing config in build.gradle.kts reads this file; when it's absent the
# release build stays unsigned (fine for local/CI compile checks).
#
# storeFile: absolute path to the release keystore (.jks). On Windows escape the
# backslashes (\\) — this file is parsed as Java Properties.
storeFile=C:\\Users\\Anon\\quoteatlas-release.jks
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME
